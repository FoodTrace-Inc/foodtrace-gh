# Database
DATABASE_URL=postgresql://username:password@localhost:5432/foodtrace

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# Email (SMTP — replace with real credentials)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@foodtrace.gh

# AWS S3 (replace with real credentials)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=af-south-1
AWS_S3_BUCKET=foodtrace-qr-codes

# Africa's Talking SMS (replace with real credentials)
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_at_username
AT_SENDER_ID=FoodTrace

# Push Notifications (replace with real key)
PUSH_SERVER_KEY=your_firebase_server_key

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
